<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NBADraftSimulator.MainPage"
             xmlns:viewModels="clr-namespace:NBADraftSimulator.ViewModels"
             Title="NBA Fantasy Draft">

    <ContentPage.BindingContext>
        <viewModels:MainViewModel />
    </ContentPage.BindingContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header NBA Style (colori NBA fissi) -->
        <Grid BackgroundColor="{StaticResource NBABlue}" Padding="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Image Source="nba_logo.png" 
                   WidthRequest="40" HeightRequest="40"
                   Aspect="AspectFit"/>

            <Label Grid.Column="1" 
                   Text="NBA FANTASY DRAFT"
                   TextColor="White"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"/>

            <Button Grid.Column="2"
                    Text="Reset"
                    BackgroundColor="{StaticResource NBARed}"
                    TextColor="White"
                    FontSize="14"
                    CornerRadius="5"
                    HeightRequest="40"
                    WidthRequest="80"
                    Command="{Binding ResetCommand}"/>
        </Grid>

        <!-- Istruzioni (con colori dinamici) -->
        <Frame Grid.Row="1" 
               Margin="10"
               Padding="10"
               BackgroundColor="{StaticResource SecondaryBackgroundColor}"
               BorderColor="{StaticResource BorderColorDynamic}"
               CornerRadius="5">
            <Label Text="Imposta i pesi (più alto = più probabile ultima scelta) e scegli chi escludere dalla pick #1"
                   TextColor="{StaticResource TextColor}"
                   FontSize="14"
                   HorizontalOptions="Center"
                   LineBreakMode="WordWrap"/>
        </Frame>

        <!-- Lista Squadre -->
        <CollectionView Grid.Row="2" 
                        ItemsSource="{Binding Squadre}"
                        Margin="10">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,3" 
                           Padding="8"
                           Style="{StaticResource {x:Type Frame}}"
                           HeightRequest="70">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Cerchio colore squadra -->
                            <BoxView Color="{Binding ColorePrimario}"
                                     WidthRequest="40" 
                                     HeightRequest="40"
                                     CornerRadius="20"/>

                            <Label Grid.Column="1" 
                                   Text="{Binding Nome}"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center"
                                   Margin="10,0"
                                   TextColor="{StaticResource TextColor}"/>

                            <!-- Slider peso -->
                            <Grid Grid.Column="2" 
                                  VerticalOptions="Center"
                                  WidthRequest="130">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Label Text="{Binding Peso, StringFormat='Peso: {0}'}"
                                       Style="{StaticResource StatsLabel}"
                                       HorizontalOptions="Center"/>

                                <Slider Grid.Row="1"
                                        Minimum="1" 
                                        Maximum="100"
                                        Value="{Binding Peso}"
                                        MinimumTrackColor="{StaticResource NBABlue}"
                                        MaximumTrackColor="{StaticResource SecondaryTextColor}"
                                        ThumbColor="{StaticResource NBARed}"/>
                            </Grid>

                            <!-- Switch per esclusione ultima scelta -->
                            <Grid Grid.Column="3" 
                                  VerticalOptions="Center"
                                  HorizontalOptions="Center"
                                  WidthRequest="60">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Label Text="No #1"
                                       FontSize="10"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource NBARed}"
                                       HorizontalOptions="Center"/>

                                <Switch Grid.Row="1"
                                        IsToggled="{Binding EscludiDaUltimaScelta}"
                                        OnColor="{StaticResource NBARed}"
                                        ThumbColor="{StaticResource NBAGold}"
                                        HorizontalOptions="Center"
                                        Scale="0.9"/>
                            </Grid>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Footer con bottoni -->
        <Grid Grid.Row="3" Padding="10" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Text="➕ AGGIUNGI SQUADRA"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    FontSize="16"
                    CornerRadius="5"
                    HeightRequest="60"
                    Command="{Binding AggiungiSquadraCommand}"/>

            <Button Grid.Column="1"
                    Text="🏀 INIZIA DRAFT 🏀"
                    BackgroundColor="{StaticResource NBARed}"
                    TextColor="White"
                    FontSize="18"
                    FontAttributes="Bold"
                    CornerRadius="5"
                    HeightRequest="60"
                    Command="{Binding StartDraftCommand}"
                    IsEnabled="{Binding PuoiIniziareDraft}"/>
        </Grid>
    </Grid>
</ContentPage>