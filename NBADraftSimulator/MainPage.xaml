<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NBADraftSimulator.MainPage"
             xmlns:viewModels="clr-namespace:NBADraftSimulator.ViewModels"
             Title="NBA Fantasy Draft">

    <ContentPage.BindingContext>
        <viewModels:MainViewModel />
    </ContentPage.BindingContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header NBA Style -->
        <Grid BackgroundColor="#1D428A" Padding="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Image Source="nba_logo.png" 
                   WidthRequest="40" HeightRequest="40"
                   Aspect="AspectFit"/>

            <Label Grid.Column="1" 
                   Text="NBA FANTASY DRAFT"
                   TextColor="White"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"/>

            <Button Grid.Column="2"
                    Text="Reset"
                    BackgroundColor="#C8102E"
                    TextColor="White"
                    FontSize="14"
                    CornerRadius="5"
                    HeightRequest="40"
                    WidthRequest="80"
                    Command="{Binding ResetCommand}"/>
        </Grid>

        <!-- Istruzioni -->
        <Frame Grid.Row="1" 
               Margin="10"
               Padding="10"
               BackgroundColor="#F5F5F5"
               CornerRadius="5">
            <Label Text="Imposta i pesi delle squadre (più alto = più probabilità prime scelte)"
                   TextColor="#333333"
                   FontSize="14"
                   HorizontalOptions="Center"/>
        </Frame>

        <!-- Lista Squadre -->
        <CollectionView Grid.Row="2" 
                        ItemsSource="{Binding Squadre}"
                        Margin="10">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,5" 
                           Padding="10"
                           CornerRadius="5"
                           HasShadow="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Cerchio colore squadra -->
                            <BoxView Color="{Binding ColorePrimario}"
                                     WidthRequest="40" 
                                     HeightRequest="40"
                                     CornerRadius="20"/>

                            <Label Grid.Column="1" 
                                   Text="{Binding Nome}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   VerticalOptions="Center"
                                   Margin="10,0"/>

                            <!-- Slider peso -->
                            <Grid Grid.Column="2" 
                                  VerticalOptions="Center"
                                  WidthRequest="150">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Label Text="{Binding Peso, StringFormat='Peso: {0}'}"
                                       FontSize="12"
                                       HorizontalOptions="Center"/>

                                <Slider Grid.Row="1"
                                        Minimum="1" 
                                        Maximum="100"
                                        Value="{Binding Peso}"
                                        MinimumTrackColor="#1D428A"
                                        MaximumTrackColor="#CCCCCC"
                                        ThumbColor="#C8102E"/>
                            </Grid>

                            <!-- Bottone rimuovi -->
                            <Button Grid.Column="3"
                                    Text="✖"
                                    BackgroundColor="Transparent"
                                    TextColor="#FF4444"
                                    FontSize="18"
                                    WidthRequest="40"
                                    HeightRequest="40"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:MainViewModel}}, Path=RimuoviSquadraCommand}"
                                    CommandParameter="{Binding .}"/>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Footer con bottoni -->
        <Grid Grid.Row="3" Padding="10" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Text="➕ AGGIUNGI SQUADRA"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    FontSize="16"
                    CornerRadius="5"
                    HeightRequest="60"
                    Command="{Binding AggiungiSquadraCommand}"/>

            <Button Grid.Column="1"
                    Text="🏀 INIZIA DRAFT 🏀"
                    BackgroundColor="#C8102E"
                    TextColor="White"
                    FontSize="18"
                    FontAttributes="Bold"
                    CornerRadius="5"
                    HeightRequest="60"
                    Command="{Binding StartDraftCommand}"
                    IsEnabled="{Binding PuoiIniziareDraft}"/>
        </Grid>
    </Grid>
</ContentPage>