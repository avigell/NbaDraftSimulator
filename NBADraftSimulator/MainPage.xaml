<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NBADraftSimulator.MainPage"
             xmlns:viewModels="clr-namespace:NBADraftSimulator.ViewModels"
             Title="NBA Fantasy Draft">

    <ContentPage.BindingContext>
        <viewModels:MainViewModel />
    </ContentPage.BindingContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header NBA Style (colori NBA fissi) -->
        <Grid BackgroundColor="#1D428A" Padding="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Image Source="nba_logo.png" 
                   WidthRequest="40" HeightRequest="40"
                   Aspect="AspectFit"/>

            <Label Grid.Column="1" 
                   Text="NBA FANTASY DRAFT"
                   TextColor="White"
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"/>

            <Button Grid.Column="2"
                    Text="Reset"
                    BackgroundColor="#C8102E"
                    TextColor="White"
                    FontSize="14"
                    CornerRadius="5"
                    HeightRequest="40"
                    WidthRequest="80"
                    Command="{Binding ResetCommand}"/>
        </Grid>

        <!-- Istruzioni (colori dinamici) -->
        <Frame Grid.Row="1" 
               Margin="10"
               Padding="10"
               CornerRadius="5">
            <Label Text="Imposta i pesi (più alto = più probabile ultima scelta) e scegli chi escludere dalla pick #1"
                   FontSize="14"
                   HorizontalOptions="Center"
                   LineBreakMode="WordWrap"/>
        </Frame>

        <!-- Lista Squadre -->
        <CollectionView Grid.Row="2" 
                        ItemsSource="{Binding Squadre}"
                        Margin="10">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,3" 
                           Padding="4"
                           HeightRequest="70">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="40"/>
                            </Grid.ColumnDefinitions>

                            <!-- Nome squadra -->
                            <Label Grid.Column="0" 
                                   Text="{Binding Nome}"
                                   FontSize="15"
                                   VerticalOptions="Center"
                                   HorizontalOptions="Start"
                                   MaxLines="2"
                                   LineBreakMode="WordWrap"/>

                            <!-- Slider peso -->
                            <Grid Grid.Column="1" 
                                  VerticalOptions="Center"
                                  WidthRequest="150">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Label Text="{Binding Peso, StringFormat='Peso: {0}'}"
                                       FontSize="12"
                                       HorizontalOptions="Center"
                                       Margin="0,0,0,-5"/>

                                <Slider Grid.Row="1"
                                        Minimum="1" 
                                        Maximum="100"
                                        Value="{Binding Peso}"
                                        MinimumTrackColor="#1D428A"
                                        MaximumTrackColor="#CCCCCC"
                                        ThumbColor="#C8102E"/>
                            </Grid>

                            <!-- Switch per esclusione ultima scelta -->
                            <Grid Grid.Column="2" 
                                  VerticalOptions="Center"
                                  HorizontalOptions="Center"
                                  RowSpacing="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Label Text="No #1"
                                       FontSize="11"
                                       FontAttributes="Bold"
                                       TextColor="#C8102E"
                                       HorizontalOptions="Center"
                                       Margin="0,0,0,-8"/>

                                <Switch Grid.Row="1"
                                        IsToggled="{Binding EscludiDaUltimaScelta}"
                                        OnColor="#C8102E"
                                        ThumbColor="#FFD700"
                                        HorizontalOptions="Center"
                                        Scale="0.85"/>
                            </Grid>

                            <!-- Bottone rimuovi -->
                            <Button Grid.Column="3"
                                    Text="✖"
                                    BackgroundColor="Transparent"
                                    TextColor="#FF4444"
                                    FontSize="18"
                                    FontAttributes="Bold"
                                    WidthRequest="44"
                                    HeightRequest="44"
                                    Padding="0"
                                    Margin="0"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type viewModels:MainViewModel}}, Path=RimuoviSquadraCommand}"
                                    CommandParameter="{Binding .}"/>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Footer con bottoni -->
        <Grid Grid.Row="3" Padding="10" ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Text="➕ AGGIUNGI SQUADRA"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    FontSize="16"
                    CornerRadius="5"
                    HeightRequest="60"
                    Command="{Binding AggiungiSquadraCommand}"/>

            <Button Grid.Column="1"
                    Text="🏀 INIZIA DRAFT 🏀"
                    BackgroundColor="#C8102E"
                    TextColor="White"
                    FontSize="18"
                    FontAttributes="Bold"
                    CornerRadius="5"
                    HeightRequest="60"
                    Command="{Binding StartDraftCommand}"
                    IsEnabled="{Binding PuoiIniziareDraft}"/>
        </Grid>
    </Grid>
</ContentPage>