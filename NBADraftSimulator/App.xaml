<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NBADraftSimulator.App">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="NBABlue">#1D428A</Color>
            <Color x:Key="NBARed">#C8102E</Color>
            <Color x:Key="NBAWhite">#FFFFFF</Color>
            <Color x:Key="NBAGold">#FFD700</Color>

            <Style TargetType="Button">
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="CornerRadius" Value="5"/>
                <Setter Property="HeightRequest" Value="50"/>
            </Style>

            <Style TargetType="Frame">
                <Setter Property="CornerRadius" Value="5"/>
                <Setter Property="HasShadow" Value="True"/>
                <Setter Property="Padding" Value="10"/>
            </Style>

            <Style x:Key="NBATitle" TargetType="Label">
                <Setter Property="FontFamily" Value="Basketball"/>
                <Setter Property="FontSize" Value="28"/>
                <Setter Property="TextColor" Value="{StaticResource NBABlue}"/>
                <Setter Property="HorizontalOptions" Value="Center"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>