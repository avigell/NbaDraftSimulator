<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NBADraftSimulator.Views.DraftPage"
             Title="NBA Draft">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER (resta fisso NBA) -->
        <Grid BackgroundColor="#1D428A" Padding="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Image Source="nba_logo.png" 
                   WidthRequest="30" HeightRequest="30"/>

            <Label x:Name="lblTitoloDraft"
                   Grid.Column="1" 
                   Text="DRAFT 2024"
                   TextColor="White"
                   FontSize="20"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"/>
        </Grid>

        <!-- AREA CENTRALE -->
        <Grid Grid.Row="1" 
              VerticalOptions="Center"
              HorizontalOptions="Center">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Annuncio (tema automatico) -->
            <Label x:Name="lblAnnuncio"
                   Text="La scelta numero 1 va a..."
                   FontSize="24"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Margin="0,0,0,30"
                   Opacity="0"/>

            <!-- Countdown -->
            <Label x:Name="lblCountdown"
                   Grid.Row="1"
                   Text="3"
                   TextColor="#C8102E"
                   FontSize="72"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Opacity="0"
                   Scale="0.5"/>

            <!-- Logo gigante -->
            <Image x:Name="imgSquadraLogo"
                   Grid.Row="1"
                   WidthRequest="200"
                   HeightRequest="200"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   IsVisible="False"
                   Opacity="0"/>

            <!-- Logo finale -->
            <Image x:Name="imgLogo"
                   Grid.Row="2"
                   WidthRequest="200"
                   HeightRequest="200"
                   Margin="0,30"
                   Opacity="0"/>

            <!-- Nome squadra (tema automatico DI DEFAULT) -->
            <Label x:Name="lblSquadra"
                   Grid.Row="3"
                   Text=""
                   FontSize="36"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Opacity="0"/>
        </Grid>

        <!-- Bottone - sempre presente, visibilità gestita con Opacity -->
        <Button Grid.Row="3"
                x:Name="btnProssimaScelta"
                Text="PROSSIMA SCELTA"
                BackgroundColor="#C8102E"
                TextColor="White"
                FontSize="20"
                FontAttributes="Bold"
                CornerRadius="0"
                HeightRequest="70"
                Clicked="OnProssimaSceltaClicked"
                Opacity="1"/>

        <Button Grid.Row="3"
                x:Name="btnVaiAlRiepilogo"
                Text="🏆 RIEPILOGO DRAFT 🏆"
                BackgroundColor="#C8102E"
                TextColor="White"
                FontSize="20"
                FontAttributes="Bold"
                CornerRadius="0"
                HeightRequest="70"
                Clicked="OnVaiAlRiepilogoClicked"
                Opacity="1"/>
    </Grid>
</ContentPage>